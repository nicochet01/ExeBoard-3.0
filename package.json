{
  "name": "exeboard",
  "productName": "ExeBoard",
  "version": "3.0.7",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "postdist": "powershell -Command \"Remove-Item -Recurse -Force dist\\builder-*.yml, dist\\builder-*.yaml -ErrorAction SilentlyContinue\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.4",
    "ini": "^6.0.0",
    "ts-node": "^10.9.2"
  },
  "build": {
    "appId": "com.viasoft.exeboard",
    "asar": true,
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "**/*",
      "assets/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "nicochet01",
        "repo": "ExeBoard-3.0"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "ExeBoard.${ext}",
      "icon": "assets/LOGO_EXEBOARD.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "differentialPackage": false
    }

  }
}